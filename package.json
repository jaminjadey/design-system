{
  "name": "demo-design-system",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "pnpm lint:root && turbo run lint && pnpm lint:styles",
    "lint:root": "eslint scripts eslint.config.mjs stylelint.config.mjs --max-warnings=0",
    "lint:styles": "stylelint \"apps/**/*.css\" \"packages/**/*.css\"",
    "typecheck": "turbo run typecheck",
    "format:check": "prettier . --check && node scripts/format-check.mjs",
    "format": "prettier . --write",
    "private:check": "node scripts/check-private-paths.mjs",
    "tokens:build": "pnpm --filter @demo-ds/tokens build",
    "tokens:quality": "pnpm tokens:build && pnpm tokens:quality:check",
    "tokens:quality:check": "node scripts/check-token-quality.mjs",
    "tokens:import": "pnpm --filter @demo-ds/token-pipeline import:raw",
    "tokens:import:raw": "pnpm --filter @demo-ds/token-pipeline import:raw",
    "tokens:scan": "pnpm --filter @demo-ds/token-pipeline scan:fixtures",
    "repo:scan": "pnpm --filter @demo-ds/token-pipeline build && node scripts/repo-scan.mjs",
    "package:check": "node scripts/check-package-exports.mjs",
    "architecture:check": "node scripts/check-architecture-boundaries.mjs",
    "storybook": "pnpm --filter @demo-ds/storybook storybook"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.13.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0"
  }
}
