{
  "name": "@demo-ds/tokens",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./token-names": {
      "types": "./dist/token-names.d.ts",
      "default": "./dist/token-names.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens.light.css": "./dist/tokens.light.css",
    "./tokens.dark.css": "./dist/tokens.dark.css",
    "./canonical.json": "./dist/canonical.json",
    "./metadata.json": "./dist/metadata.json",
    "./token-docs.json": "./dist/token-docs.json",
    "./build-report.json": "./dist/build-report.json"
  },
  "scripts": {
    "build": "pnpm --filter @demo-ds/token-pipeline build && node ../token-pipeline/dist/cli/buildCanonical.js ./fixtures/extracted ./dist ../../token-pipeline.config.json",
    "test": "node --test tests/*.test.mjs",
    "lint": "node -e \"console.log('tokens placeholder lint passed')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@demo-ds/token-pipeline": "workspace:*"
  }
}
