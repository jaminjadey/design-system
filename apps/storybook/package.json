{
  "name": "@demo-ds/storybook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "storybook build",
    "test": "pnpm run build && pnpm run test:qa",
    "test:qa": "node --test tests/*.test.mjs",
    "lint": "eslint .storybook src tests --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@demo-ds/components": "workspace:*",
    "@demo-ds/mantine-theme": "workspace:*",
    "@demo-ds/tokens": "workspace:*",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "storybook": "^10.4.6",
    "vite": "^8.1.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1"
  }
}
